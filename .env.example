# Telegram Subscription Bot environment variables

# Required
TELEGRAM_BOT_TOKEN=your_bot_token_here
OWNER_ID=123456789

# Optional access control
ALLOWED_USER_IDS=

# Optional network settings
PROXY_PORT=7890

# Optional runtime toggles
ENABLE_LATENCY_TESTER=true
ENABLE_MONITOR=true
ENABLE_GEO_LOOKUP=true
VERIFY_SSL=true
ENABLE_OWNER_LEGACY_READ_COMMANDS=true
ENABLE_USER_COMPACT_SUB_BUTTONS=true
ENABLE_WEB_ADMIN=false
APP_RUN_MODE=legacy_polling

# Optional cache tuning
URL_CACHE_MAX_SIZE=5000
URL_CACHE_TTL_SECONDS=86400

# Optional web admin settings
WEB_ADMIN_HOST=127.0.0.1
WEB_ADMIN_PORT=8080
WEB_ADMIN_TOKEN=
WEB_ADMIN_PUBLIC_URL=
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_SESSION_TTL_SECONDS=28800
WEB_ADMIN_ALLOW_HEADER_TOKEN=false
WEB_ADMIN_COOKIE_SECURE=true
WEB_ADMIN_TRUST_PROXY=false
WEB_ADMIN_LOGIN_WINDOW_SECONDS=600
WEB_ADMIN_LOGIN_MAX_ATTEMPTS=10
WEB_ADMIN_REDIS_URL=

# Optional performance tuning
LATENCY_TEST_CONCURRENCY=30
GEO_LOOKUP_MAX_WORKERS=8
MAX_NODES_PER_PARSE=300
MAX_GEO_QUERIES=50
PARSE_GLOBAL_CONCURRENCY=24
PARSE_USER_CONCURRENCY=6
PARSE_SLOW_THRESHOLD_SECONDS=8
PARSE_STATS_REPORT_EVERY=50
PARSE_SUCCESS_CACHE_TTL_SECONDS=12
PARSE_SUCCESS_CACHE_MAX_SIZE=512
SUB_TIMEOUT=15
SUB_DOWNLOAD_WORKERS=30
TIMEOUT_MS=6000

# Optional advanced runtime settings
API_PORT=19090
TEST_URL=http://www.gstatic.com/generate_204
PROXY_TOP_N=10
LOG_KEEP_DAYS=30
NODE_TEST_VERBOSE=false
SERVER_PROFILE=1gb
