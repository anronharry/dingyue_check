# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 代理端口
PROXY_PORT=7890
# 允许使用 Bot 的 Telegram 用户 ID 白名单（多个 ID 用英文逗号分隔）
# 查询你的 User ID: 向 @userinfobot 发送任意消息即可
# 留空则不限制任何人（不推荐！）
ALLOWED_USER_IDS=123456789

# 回调URL缓存（可选）
URL_CACHE_MAX_SIZE=500
URL_CACHE_TTL_SECONDS=86400
