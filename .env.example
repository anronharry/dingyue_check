# =============================================
# Telegram Bot 配置
# =============================================

# Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 服务器档位（影响安装哪套依赖 + 开启哪些功能）
# 256mb：仅核心功能，不装 matplotlib，适合 256MB 小内存机器
# 512mb：加测速+GEO，不装 matplotlib
# 1gb  ：全功能开启（默认）
SERVER_PROFILE=1gb
# 允许使用 Bot 的 Telegram 用户 ID（多个用英文逗号分隔）
# 查询你的 ID：向 @userinfobot 发送任何消息
# 留空则不限制任何人（不推荐！）
ALLOWED_USER_IDS=123456789

# 代理端口（如果机器人本身需要走代理访问 Telegram）
PROXY_PORT=7890

# =============================================
# 服务器档位预设（快速适配不同内存规格）
# 取消注释其中一行即可，单独开关优先级更高
# =============================================
# SERVER_PROFILE_1G=true    # 1GB+ 服务器：开启所有功能（默认）
# SERVER_PROFILE_1G=false   # 512MB-：关闭可视化图表

# =============================================
# 功能开关（精细控制，覆盖档位默认值）
# =============================================

# 📊 可视化图表报告（需要 matplotlib+seaborn，约 +80MB 内存）
# ENABLE_VISUALIZER=true

# ⚡ 节点 TCP 测速
# ENABLE_LATENCY_TESTER=true

# 🔔 后台定时监控与告警（每天 12:00 / 20:00 巡检）
# ENABLE_MONITOR=true

# 🌍 真实 IP 地理位置查询（调用 ip-api.com，有频率限制）
# ENABLE_GEO_LOOKUP=true

# =============================================
# 性能调优（可选，括号内为默认值）
# =============================================

# URL 短链缓存最大条目数（5000）
# URL_CACHE_MAX_SIZE=5000

# URL 缓存过期时间，单位秒（86400 = 24h）
# URL_CACHE_TTL_SECONDS=86400

# 节点测速最大并发数（30）
# LATENCY_TEST_CONCURRENCY=30

# 地理位置查询最大并发线程数（8）
# GEO_LOOKUP_MAX_WORKERS=8

# 单次解析最多节点数，防止 OOM（300）
# MAX_NODES_PER_PARSE=300

# 地理位置并发查询上限，避免触发 ip-api.com 限速（50）
# MAX_GEO_QUERIES=50
